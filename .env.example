# coforge environment variables
# Copy to .env and fill in your own credentials.

# Any OpenAI-compatible chat completions endpoint.
# Examples: OpenAI (https://api.openai.com/v1, gpt-4o-mini),
# OpenRouter (https://openrouter.ai/api/v1, ...), a local Ollama/LM Studio server, etc.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# router port
ROUTER_PORT=8787

# web port
WEB_PORT=5173

# B2 memory compression: on by default (coforge as usable workspace — old
# history is summarized to bound prompt-token growth). Set to false to
# reproduce the paper's prompt-replay wall (full-history replay every turn).
COMPRESS_MEMORY=true
